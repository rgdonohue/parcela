# --- LLM Provider ---
# If TOGETHER_API_KEY is set, the app uses Together.ai (production).
# Otherwise it falls back to local Ollama (development).

# Together.ai (production)
# TOGETHER_API_KEY=your-key-here
# TOGETHER_MODEL=Qwen/Qwen2.5-7B-Instruct
# TOGETHER_TIMEOUT_MS=30000

# Ollama (local development)
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=qwen2.5:7b
OLLAMA_TIMEOUT_MS=30000

# Server
PORT=3000

# Security
# Development can omit CORS_ORIGIN and API_KEY. In production, CORS_ORIGIN must
# be a concrete origin and API_KEY must be set.
# CORS_ORIGIN=https://example.org
# API_KEY=replace-with-deployment-secret

# Set this only when the API is behind a known reverse proxy/load balancer.
# 0 means X-Forwarded-For is ignored. 1 trusts the rightmost proxy hop, 2 trusts
# the two rightmost proxy hops, etc.
TRUSTED_PROXY_COUNT=0
